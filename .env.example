# ===========================================
# HAPPENLIST ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# ===========================================

# ----- Supabase Configuration -----
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only key (never expose to client!)
# Used for admin operations and server-side data fetching
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----- Site Configuration -----
# The public URL where your site is hosted
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Optional: Analytics -----
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
ADMIN_EMAILS=admin@example.com,another-admin@example.com
SUPERADMIN_EMAILS=hazel.quimpo@gmail.com

# ----- Scraper Backend (Render) -----
# Shared secret for authenticating calls BOTH directions:
# - Render → Vercel: Bearer token on POST /api/scraper/events, /api/images/upload
# - Vercel → Render: X-API-Secret header on POST /analyze, /recheck, etc.
# Rotate on BOTH Render and Vercel if compromised.
SCRAPER_API_SECRET=

# Base URL of the Render-hosted happenlist_scraper backend (no trailing slash).
# Used by /admin/import, rescrape button, and sold-out cron.
# e.g. https://happenlist-scraper.onrender.com
SCRAPER_API_URL=

# ----- Vercel Cron Auth -----
# Generated automatically by Vercel when you link the project. Locally, leave
# blank and the cron route allows unauthenticated requests so you can curl it.
# In production, Vercel injects this header on scheduled runs.
CRON_SECRET=